{
  "name": "smoke",
  "control_root": "/comet/shared/control/smoke",
  "placement_target": "local",
  "runtime": {
    "primary_infer_node": "local-hostd",
    "net_if": "eth0",
    "models_root": "/comet/shared/models",
    "gguf_cache_dir": "/comet/shared/models/gguf",
    "infer_log_dir": "/comet/shared/logs/infer",
    "llama_port": 8000,
    "llama_ctx_size": 4096,
    "llama_threads": 4,
    "llama_gpu_layers": 50,
    "inference_healthcheck_retries": 120,
    "inference_healthcheck_interval_sec": 5
  },
  "gateway": {
    "listen_host": "0.0.0.0",
    "listen_port": 8080,
    "server_name": "smoke.local"
  },
  "shared_disk_gb": 40,
  "nodes": [
    {
      "name": "local-hostd",
      "platform": "linux",
      "gpus": ["0"],
      "gpu_memory_mb": {
        "0": 24576
      }
    }
  ]
}
