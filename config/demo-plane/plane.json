{
  "name": "alpha",
  "control_root": "/naim/shared/control/alpha",
  "runtime": {
    "primary_infer_node": "local-hostd",
    "runtime_engine": "llama.cpp",
    "data_parallel_mode": "off",
    "worker_group_id": "alpha-workers",
    "distributed_backend": "llama_rpc",
    "worker_selection_policy": "prefer-free-then-share",
    "net_if": "eth0",
    "models_root": "/naim/shared/models",
    "model_cache_dir": "/naim/shared/models/cache",
    "runtime_log_dir": "/naim/shared/logs/infer",
    "api_port": 18097,
    "max_model_len": 8192,
    "max_num_seqs": 16,
    "rendezvous_port": 29520,
    "gguf_cache_dir": "/naim/shared/models/gguf",
    "infer_log_dir": "/naim/shared/logs/infer",
    "llama_port": 18097,
    "llama_ctx_size": 8192,
    "llama_threads": 8,
    "llama_gpu_layers": 99,
    "inference_healthcheck_retries": 300,
    "inference_healthcheck_interval_sec": 5
  },
  "gateway": {
    "listen_host": "0.0.0.0",
    "listen_port": 18097,
    "server_name": "alpha.local"
  },
  "shared_disk_gb": 200,
  "nodes": [
    {
      "name": "local-hostd",
      "platform": "linux",
      "execution_mode": "mixed",
      "gpus": ["0", "1"],
      "gpu_memory_mb": {
        "0": 97887,
        "1": 97887
      }
    },
    {
      "name": "node-b",
      "platform": "linux",
      "execution_mode": "mixed",
      "gpus": ["0"],
      "gpu_memory_mb": {
        "0": 97887
      }
    }
  ]
}
