{
  "name": "alpha",
  "control_root": "/comet/shared/control/alpha",
  "runtime": {
    "primary_infer_node": "local-hostd",
    "runtime_engine": "vllm",
    "data_parallel_mode": "off",
    "worker_group_id": "alpha-workers",
    "distributed_backend": "vllm",
    "worker_selection_policy": "prefer-free-then-share",
    "net_if": "eth0",
    "models_root": "/comet/shared/models",
    "model_cache_dir": "/comet/shared/models/cache",
    "runtime_log_dir": "/comet/shared/logs/infer",
    "api_port": 18097,
    "max_model_len": 8192,
    "tensor_parallel_size": 1,
    "pipeline_parallel_size": 1,
    "max_num_seqs": 16,
    "gpu_memory_utilization": 0.9,
    "enforce_eager": false,
    "rendezvous_port": 29520,
    "inference_healthcheck_retries": 300,
    "inference_healthcheck_interval_sec": 5
  },
  "gateway": {
    "listen_host": "0.0.0.0",
    "listen_port": 18097,
    "server_name": "alpha.local"
  },
  "shared_disk_gb": 200,
  "nodes": [
    {
      "name": "local-hostd",
      "platform": "linux",
      "execution_mode": "mixed",
      "gpus": ["0", "1"],
      "gpu_memory_mb": {
        "0": 97887,
        "1": 97887
      }
    },
    {
      "name": "node-b",
      "platform": "linux",
      "execution_mode": "mixed",
      "gpus": ["0"],
      "gpu_memory_mb": {
        "0": 97887
      }
    }
  ]
}
