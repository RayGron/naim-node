{
  "name": "dp-smoke",
  "control_root": "/comet/shared/control/dp-smoke",
  "placement_target": "local",
  "runtime": {
    "primary_infer_node": "local-hostd",
    "runtime_engine": "vllm",
    "data_parallel_mode": "auto_replicas",
    "worker_group_id": "dp-smoke-workers",
    "distributed_backend": "vllm",
    "worker_selection_policy": "prefer-free-then-share",
    "net_if": "eth0",
    "models_root": "/comet/shared/models",
    "model_cache_dir": "/comet/shared/models/cache",
    "runtime_log_dir": "/comet/shared/logs/infer",
    "api_port": 18198,
    "max_model_len": 4096,
    "tensor_parallel_size": 1,
    "pipeline_parallel_size": 2,
    "max_num_seqs": 16,
    "gpu_memory_utilization": 0.9,
    "enforce_eager": false,
    "rendezvous_port": 29531,
    "inference_healthcheck_retries": 120,
    "inference_healthcheck_interval_sec": 5
  },
  "gateway": {
    "listen_host": "0.0.0.0",
    "listen_port": 18198,
    "server_name": "dp-smoke.local"
  },
  "shared_disk_gb": 40,
  "nodes": [
    {
      "name": "local-hostd",
      "platform": "linux",
      "execution_mode": "mixed",
      "gpus": ["0"],
      "gpu_memory_mb": {
        "0": 97887
      }
    }
  ]
}
