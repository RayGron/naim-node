{
  auto_https off
  admin off
}

:8080 {
  root * /srv

  route {
    @health path /health
    respond @health "ok" 200

    @events path /api/v1/events/stream*
    reverse_proxy @events {$COMET_CONTROLLER_UPSTREAM}

    @api path /api/*
    reverse_proxy @api {$COMET_CONTROLLER_UPSTREAM}

    try_files {path} /index.html
    file_server
  }
}
