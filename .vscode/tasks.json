    {
      "label": "Comet Windows x64: Build Debug",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts\\windows\\build-target.ps1",
        "x64",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "linux": {
        "command": "bash",
        "args": [
          "-lc",
          "powershell.exe -ExecutionPolicy Bypass -File \"$(wslpath -w \"${workspaceFolder}\")\\\\scripts\\\\windows\\\\build-target.ps1\" x64 Debug"
        ]
      }
