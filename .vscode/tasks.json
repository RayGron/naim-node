      "label": "Comet Linux x64: Build Debug",
      "type": "shell",
      "command": "./scripts/build-target.sh",
      "args": [
        "linux",
        "x64",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": "$gcc",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
