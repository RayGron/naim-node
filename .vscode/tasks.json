{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Naim Host: Build Debug",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "host_arch=$(uname -m); case \"$host_arch\" in x86_64) target_arch=x64 ;; aarch64|arm64) target_arch=arm64 ;; *) echo \"unsupported host arch: $host_arch\" >&2; exit 1 ;; esac; ./scripts/build-target.sh linux \"$target_arch\" Debug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "osx": {
        "command": "bash",
        "args": [
          "-lc",
          "host_arch=$(uname -m); case \"$host_arch\" in x86_64) target_arch=x64 ;; arm64) target_arch=arm64 ;; *) echo \"unsupported host arch: $host_arch\" >&2; exit 1 ;; esac; ./scripts/build-target.sh macos \"$target_arch\" Debug"
        ]
      },
      "windows": {
        "command": "powershell.exe",
        "args": [
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          "$arch = if ($env:PROCESSOR_ARCHITECTURE -eq 'ARM64') { 'arm64' } else { 'x64' }; & .\\scripts\\windows\\build-target.ps1 $arch Debug"
        ],
        "problemMatcher": "$msCompile"
      }
    },
    {
      "label": "Naim Host: Build Release",
      "type": "shell",
      "command": "bash",
