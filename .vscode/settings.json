{
  "cmake.useCMakePresets": "always",
  "cmake.cmakePath": "/usr/bin/cmake",
  "cmake.configureOnOpen": false,
  "cmake.defaultConfigurePreset": "linux-x64",
  "cmake.defaultBuildPreset": "linux-x64",
  "C_Cpp.default.compilerPath": "/usr/bin/clang++",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/common/include",
    "${workspaceFolder}/vcpkg_installed/x64-linux-root/x64-linux/include",
    "\\\\wsl.localhost\\Ubuntu\\usr\\include\\c++\\11",
    "\\\\wsl.localhost\\Ubuntu\\usr\\include\\x86_64-linux-gnu\\c++\\11",
    "\\\\wsl.localhost\\Ubuntu\\usr\\include\\c++\\11\\backward",
    "\\\\wsl.localhost\\Ubuntu\\usr\\lib\\gcc\\x86_64-linux-gnu\\11\\include",
    "\\\\wsl.localhost\\Ubuntu\\usr\\local\\include",
    "\\\\wsl.localhost\\Ubuntu\\usr\\include\\x86_64-linux-gnu",
    "\\\\wsl.localhost\\Ubuntu\\usr\\include"
  ],
  "C_Cpp.default.cppStandard": "c++20",
  "C_Cpp.intelliSenseEngine": "default",
  "files.associations": {
    "*.h": "cpp",
    "*.tcc": "cpp"
  }
}
